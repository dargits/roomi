{
  "info": {
    "_postman_id": "roomi-assign-room-timeslot-full-v1",
    "name": "Roomi - Kiem thu Gan Phong & Goi Thoi Gian",
    "description": "Collection kiem thu day du chuc nang: Xay dung va kiem tra goi thoi gian khi gan phong.\nBao gom: Happy path (thanh cong), Ngay sai, Thieu thong tin, Conflict lich, Sai trang thai.\nBase URL: http://localhost:8080\nCach dung: Chay thu tu 0 -> 1 -> 2 -> 3 -> 4 -> 5",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "token",        "value": "THAY_TOKEN_O_DAY",      "type": "string",
      "description": "Lay token sau khi POST /api/v1/auth/login" },
    { "key": "guestId",      "value": "1",  "type": "string",
      "description": "ID guest ton tai trong DB" },
    { "key": "roomTypeId",   "value": "1",  "type": "string",
      "description": "ID loai phong ton tai trong DB" },
    { "key": "roomId",       "value": "1",  "type": "string",
      "description": "ID phong thuoc dung roomType, con trong" },
    { "key": "roomIdWrongType", "value": "2", "type": "string",
      "description": "ID phong thuoc KHAC roomType cua booking" },
    { "key": "bookingId",    "value": "",   "type": "string",
      "description": "Tu dong set boi test 1.1 (tao booking moi)" },
    { "key": "bookingId_noRoom", "value": "", "type": "string",
      "description": "Booking chua gan phong - set boi test 1.2" }
  ],
  "item": [

    {
      "name": "0. Tien xu ly - Tao du lieu chuan bi",
      "item": [
        {
          "name": "0.1 Tao Booking co room (Happy path - luu bookingId)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Co truong data', () => pm.expect(pm.response.json().data).to.exist);",
                "pm.test('mess = Tao booking thanh cong', () => pm.expect(pm.response.json().mess).to.exist);",
                "const data = pm.response.json().data;",
                "pm.test('status = NEW', () => pm.expect(data.status).to.eql('NEW'));",
                "pm.test('roomId duoc gan', () => pm.expect(data.roomId).to.not.be.null);",
                "// Luu bookingId de dung o cac test sau",
                "if (data && data.id) { pm.collectionVariables.set('bookingId', data.id); }",
                "console.log('bookingId moi tao:', data.id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"roomId\": {{roomId}},\n  \"checkInDate\": \"2026-10-01\",\n  \"checkOutDate\": \"2026-10-05\",\n  \"source\": \"WALK_IN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings",
              "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"]
            }
          }
        },
        {
          "name": "0.2 Tao Booking CHUA gan phong (luu bookingId_noRoom)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "const data = pm.response.json().data;",
                "pm.test('roomId = null (chua gan phong)', () => pm.expect(data.roomId).to.be.null);",
                "pm.test('status = NEW', () => pm.expect(data.status).to.eql('NEW'));",
                "if (data && data.id) { pm.collectionVariables.set('bookingId_noRoom', data.id); }",
                "console.log('bookingId_noRoom:', data.id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"checkInDate\": \"2026-11-01\",\n  \"checkOutDate\": \"2026-11-05\",\n  \"source\": \"PHONE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings",
              "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"]
            }
          }
        }
      ]
    },

    {
      "name": "1. Happy Path - Gan phong thanh cong",
      "item": [
        {
          "name": "1.1 Gan phong hop le cho booking chua co phong",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('mess = Gan phong thanh cong', () => pm.expect(pm.response.json().mess).to.eql('G\\u00e1n ph\\u00f2ng th\\u00e0nh c\\u00f4ng'));",
                "const data = pm.response.json().data;",
                "pm.test('roomId duoc set', () => pm.expect(data.roomId).to.not.be.null);",
                "pm.test('roomNumber co gia tri', () => pm.expect(data.roomNumber).to.not.be.null);",
                "pm.test('expectedPrice > 0', () => pm.expect(data.expectedPrice).to.be.above(0));",
                "pm.test('nights > 0', () => pm.expect(data.nights).to.be.above(0));",
                "pm.test('status van la NEW', () => pm.expect(data.status).to.eql('NEW'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId_noRoom}}/assign-room?roomId={{roomId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","bookings","{{bookingId_noRoom}}","assign-room"],
              "query": [{ "key": "roomId", "value": "{{roomId}}" }]
            }
          }
        },
        {
          "name": "1.2 Gan lai phong cho chinh booking do (khong conflict voi minh)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 - Gan lai cung phong khong bao loi', () => pm.response.to.have.status(200));",
                "const data = pm.response.json().data;",
                "pm.test('roomId khong doi', () => pm.expect(data.roomId).to.eql(parseInt(pm.collectionVariables.get('roomId'))));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId_noRoom}}/assign-room?roomId={{roomId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","bookings","{{bookingId_noRoom}}","assign-room"],
              "query": [{ "key": "roomId", "value": "{{roomId}}" }]
            }
          }
        },
        {
          "name": "1.3 Xem calendar phong sau khi gan (kiem tra slot xuat hien)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const data = pm.response.json().data;",
                "pm.test('Co truong bookings', () => pm.expect(data.bookings).to.be.an('array'));",
                "pm.test('Co it nhat 1 booking trong lich', () => pm.expect(data.bookings.length).to.be.above(0));",
                "const slot = data.bookings[0];",
                "pm.test('Slot co checkInDate', () => pm.expect(slot.checkInDate).to.exist);",
                "pm.test('Slot co checkOutDate', () => pm.expect(slot.checkOutDate).to.exist);",
                "pm.test('Slot co nights > 0', () => pm.expect(slot.nights).to.be.above(0));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/calendar/rooms/{{roomId}}?checkIn=2026-10-01&checkOut=2026-10-31",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","calendar","rooms","{{roomId}}"],
              "query": [
                { "key": "checkIn",  "value": "2026-10-01" },
                { "key": "checkOut", "value": "2026-10-31" }
              ]
            }
          }
        },
        {
          "name": "1.4 Tim phong trong - ket qua khong chua phong da bi dat",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const rooms = pm.response.json().data;",
                "pm.test('Ket qua la array', () => pm.expect(rooms).to.be.an('array'));",
                "const occupiedRoomId = parseInt(pm.collectionVariables.get('roomId'));",
                "const conflictRoom = rooms.find(r => r.roomId === occupiedRoomId);",
                "pm.test('Phong da dat khong co trong danh sach available', () => pm.expect(conflictRoom).to.be.undefined);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/calendar/available-rooms?checkIn=2026-10-01&checkOut=2026-10-05",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","calendar","available-rooms"],
              "query": [
                { "key": "checkIn",  "value": "2026-10-01" },
                { "key": "checkOut", "value": "2026-10-05" }
              ]
            }
          }
        }
      ]
    },

