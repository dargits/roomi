              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"checkInDate\": \"2020-01-01\",\n  \"checkOutDate\": \"2020-01-05\",\n  \"source\": \"WALK_IN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"] }
          }
        },
        {
          "name": "1.4 checkInDate định dạng sai (không phải yyyy-MM-dd)",
          "event": [{ "listen": "test", "script": { "exec": [
