{
  "info": {
    "_postman_id": "roomi-timeslot-error-tests-v1",
    "name": "Roomi — Kiểm thử khoảng ngày sai & thiếu thông tin",
    "description": "Collection kiểm thử các trường hợp lỗi: khoảng ngày sai, thiếu field bắt buộc, trùng lịch phòng — dùng cho POST /api/v1/bookings và PATCH /{id}/assign-room, GET /api/v1/calendar/*",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8080",      "type": "string" },
    { "key": "token",     "value": "your-session-token-here",    "type": "string" },
    { "key": "guestId",   "value": "1",                          "type": "string" },
    { "key": "roomTypeId","value": "1",                          "type": "string" },
    { "key": "roomId",    "value": "1",                          "type": "string" },
    { "key": "bookingId", "value": "1",                          "type": "string" }
  ],
  "item": [

    {
      "name": "1. Tạo Booking — Khoảng ngày sai",
      "item": [
        {
          "name": "1.1 checkInDate > checkOutDate",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('code BOOK_002', () => pm.expect(pm.response.json().code).to.eql('BOOK_002'));",
            "pm.test('mess chứa checkInDate', () => pm.expect(pm.response.json().mess).to.include('checkInDate'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"checkInDate\": \"2026-09-10\",\n  \"checkOutDate\": \"2026-09-05\",\n  \"source\": \"WALK_IN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"] }
          }
        },
        {
          "name": "1.2 checkInDate == checkOutDate (cùng ngày)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
