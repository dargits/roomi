            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"checkInDate\": \"2026-09-10\",\n  \"checkOutDate\": \"next-monday\",\n  \"source\": \"WALK_IN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"] }
          }
        }
      ]
    },

