            "pm.test('mess chứa phải trước', () => pm.expect(pm.response.json().mess).to.include('phải trước'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": {{guestId}},\n  \"roomTypeId\": {{roomTypeId}},\n  \"checkInDate\": \"2026-09-10\",\n  \"checkOutDate\": \"2026-09-10\",\n  \"source\": \"WALK_IN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"] }
          }
        },
        {
          "name": "1.3 checkInDate trong quá khứ (hôm qua)",
