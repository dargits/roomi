    {
      "name": "5. SeasonalRate - Tra giá đúng ngày",
      "description": "Kiểm tra price trả về đúng cho từng ngày cụ thể bằng cách:\n  1. Lấy danh sách seasonal rates của roomType\n  2. Tìm rate chứa ngày cần tra\n  3. Xác nhận price khớp với dữ liệu đã tạo\n\nDữ liệu đã setup từ folder trước:\n  - 2026-08-20 ~ 2026-08-31 : price 750000\n  - 2026-09-01 ~ 2026-09-30 : price 800000\n  - 2026-10-01 ~ 2026-10-15 : price 780000",
      "item": [
        {
          "name": "5.1 Tra giá ngày 2026-08-25 (phải trả 750000)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const res = pm.response.json();",
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('data là array không rỗng', () => {",
            "  pm.expect(res.data).to.be.an('array');",
            "  pm.expect(res.data.length).to.be.above(0);",
            "});",
            "",
            "const queryDate = '2026-08-25';",
            "const expectedPrice = 750000;",
            "",
            "// Tìm seasonal rate chứa ngày 2026-08-25",
            "const matched = res.data.find(sr => {",
            "  return queryDate >= sr.startDate && queryDate <= sr.endDate;",
            "});",
